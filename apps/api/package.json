{
  "name": "@arc-checkout/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@arc-checkout/chain-config": "workspace:*",
    "@arc-checkout/cctp": "workspace:*",
    "@arc-checkout/database": "workspace:*",
    "@arc-checkout/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "supertest": "^7.1.1",
    "@types/supertest": "^6.0.3",
    "tsx": "^4.19.4",
    "vitest": "^3.2.3"
  }
}
