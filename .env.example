# Core
NODE_ENV=development
DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_PORT=4000
WORKER_PORT=4001
DATABASE_URL=postgresql://arc:arc@localhost:5432/arc_checkout?schema=public

# Public wallet configuration (safe for the browser)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CHECKOUT_FACTORY_ADDRESS=
NEXT_PUBLIC_MERCHANT_REGISTRY_ADDRESS=
ARC_CHECKOUT_FACTORY_ADDRESS=
ARC_MERCHANT_REGISTRY_ADDRESS=
ARC_DEPLOYMENT_BLOCK=
ARC_INDEXER_PAGE_SIZE=1000

# Testnet RPCs
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Circle CCTP sandbox (public endpoint; API key is optional today)
CIRCLE_API_BASE_URL=https://iris-api-sandbox.circle.com
CIRCLE_API_KEY=

# Never expose these values to the browser
SETTLER_PRIVATE_KEY=
DEPLOYER_KEYSTORE_PATH=
FOUNDRY_ACCOUNT=arc-checkout-deployer
PROTOCOL_TREASURY=
PROTOCOL_FEE_BPS=25
MIN_DEPLOYER_GAS_WEI=100000000000000000
WEBHOOK_ENCRYPTION_KEY=
AUTH_DOMAIN=localhost:3000
ALLOWED_WEBHOOK_HOSTS=
LOG_LEVEL=info
