{
  "name": "arc-crosschain-checkout",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:contracts": "pnpm --filter @arc-checkout/contracts test",
    "test:e2e": "pnpm --filter @arc-checkout/web test:e2e",
    "deploy:contracts": "pnpm --filter @arc-checkout/contracts deploy",
    "seed": "pnpm --filter @arc-checkout/database seed",
    "db:generate": "pnpm --filter @arc-checkout/database generate",
    "db:migrate": "pnpm --filter @arc-checkout/database migrate",
    "verify:chains": "pnpm --filter @arc-checkout/chain-config verify",
    "security:scan": "node scripts/security-scan.mjs",
    "demo:up": "docker compose up -d postgres",
    "demo:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "prettier-plugin-solidity": "^2.1.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
