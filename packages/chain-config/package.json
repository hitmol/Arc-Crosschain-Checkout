{
  "name": "@arc-checkout/chain-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "tsx src/verify-official.ts"
  },
  "dependencies": {
    "viem": "^2.31.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "vitest": "^3.2.3"
  }
}
