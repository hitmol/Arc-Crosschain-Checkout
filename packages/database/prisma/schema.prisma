generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  OPEN
  PARTIALLY_FUNDED
  FUNDED
  SETTLING
  SETTLED
  REFUNDED
  CANCELLED
  EXPIRED
}

enum AttemptStatus {
  QUOTED
  REGISTERED
  APPROVING
  BURN_SUBMITTED
  SOURCE_CONFIRMED
  ATTESTING
  RECOVERABLE
  ARC_MINTED
  SETTLING
  SETTLED
  FAILED
  EXPIRED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  RETRYING
  FAILED
}

model Merchant {
  id            String             @id @default(uuid())
  walletAddress String             @unique
  payoutAddress String
  metadataHash  String?
  displayName   String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  intents       PaymentIntent[]
  webhooks      WebhookEndpoint[]
  apiKeys       MerchantApiKey[]
  transactions  ChainTransaction[]
}

model PaymentIntent {
  id                        String             @id @default(uuid())
  slug                      String             @unique
  orderId                   String
  orderIdBytes32            String
  expectedAmount            BigInt
  fundedAmount              BigInt             @default(0)
  refundAddress             String?
  payoutAddress             String
  vaultAddress              String?            @unique
  metadataHash              String?
  description               String?
  status                    PaymentStatus      @default(OPEN)
  expiresAt                 DateTime
  createChainId             Int                @default(5042002)
  createTransactionHash     String?
  arcMintTransactionHash    String?
  settlementTransactionHash String?
  settlementLockId          String?
  settlementLockedAt        DateTime?
  settlementMerchantAmount  BigInt?
  protocolFeeAmount         BigInt?
  excessAmount              BigInt?
  refundedAmount            BigInt?
  settledAt                 DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  merchantId                String
  merchant                  Merchant           @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  attempts                  PaymentAttempt[]
  quotes                    PaymentQuote[]
  transactions              ChainTransaction[]

  @@unique([merchantId, orderId])
  @@unique([merchantId, orderIdBytes32])
  @@unique([createChainId, createTransactionHash])
  @@index([merchantId, createdAt])
  @@index([status, expiresAt])
}

model PaymentAttempt {
  id                    String        @id @default(uuid())
  attemptIdentifier     String?       @unique
  active                Boolean       @default(true)
  vaultAddress          String?
  orderIdBytes32        String?
  sourceChainId         Int
  destinationChainId    Int           @default(5042002)
  customerAddress       String
  refundAddress         String?
  destinationAmount     BigInt?
  quotedSourceAmount    BigInt
  maximumSourceAmount   BigInt?
  maxFee                BigInt?
  quoteExpiresAt        DateTime?
  nonce                 BigInt?
  attemptExpiresAt      DateTime?
  authorizationDigest   String?
  signature             String?
  registeredTransactionHash String?
  clientSecretHash       String?
  bridgeResult           Json?
  bridgeRecoverable      Boolean       @default(false)
  status                AttemptStatus @default(QUOTED)
  sourceTransactionHash String?       @unique
  cctpMessageId         String?       @unique
  sourceDomain          Int?
  destinationDomain     Int?
  messageHash           String?       @unique
  eventNonce            String?
  burnToken             String?
  mintRecipient         String?
  burnAmount            BigInt?
  mintedAmount          BigInt?
  finalityThreshold     Int?
  sourceSender          String?
  forwardState          String?
  forwardTxHash         String?       @unique
  cctpMessage           String?
  cctpAttestation       String?
  errorCode             String?
  errorMessage          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  paymentIntentId       String
  paymentIntent         PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  quoteId               String?       @unique
  quote                 PaymentQuote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([paymentIntentId, active])
  @@unique([sourceDomain, eventNonce])
}

model PaymentQuote {
  id                         String         @id @default(uuid())
  sourceChainId              Int
  destinationChainId         Int            @default(5042002)
  requestedDestinationAmount BigInt
  protocolFee                BigInt
  forwardFee                 BigInt
  feeBuffer                  BigInt
  maxFee                     BigInt
  maximumSourceAmount        BigInt
  finalityThreshold          Int
  transferSpeed              String
  expiresAt                  DateTime
  usedAt                     DateTime?
  createdAt                  DateTime       @default(now())
  paymentIntentId            String
  paymentIntent              PaymentIntent  @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  attempt                    PaymentAttempt?

  @@index([paymentIntentId, expiresAt])
}

model ChainTransaction {
  id              String         @id @default(uuid())
  chainId         Int
  transactionHash String
  logIndex        Int            @default(0)
  blockNumber     BigInt
  blockHash       String
  contractAddress String
  type            String
  payload         Json
  observedAt      DateTime       @default(now())
  merchantId      String?
  merchant        Merchant?      @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  paymentIntentId String?
  paymentIntent   PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)

  @@unique([chainId, transactionHash, logIndex])
}

model AuthChallenge {
  id            String    @id @default(uuid())
  walletAddress String
  chainId       Int
  domain        String
  nonceHash     String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([walletAddress, expiresAt])
}

model MerchantSession {
  id            String    @id @default(uuid())
  tokenHash     String    @unique
  walletAddress String
  chainId       Int
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())

  @@index([walletAddress, expiresAt])
}

model MerchantApiKey {
  id         String    @id @default(uuid())
  name       String
  keyPrefix  String
  keyHash    String    @unique
  scopes     String[]
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  merchantId String
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, revokedAt])
}

model WebhookEndpoint {
  id              String            @id @default(uuid())
  url             String
  encryptedSecret String
  events          String[]
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  merchantId      String
  merchant        Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]

  @@unique([merchantId, url])
}

model WebhookDelivery {
  id                String                @id @default(uuid())
  eventId           String                @unique
  eventType         String
  payload           Json
  status            WebhookDeliveryStatus @default(PENDING)
  attempts          Int                   @default(0)
  lastStatusCode    Int?
  lastError         String?
  nextAttemptAt     DateTime              @default(now())
  deliveredAt       DateTime?
  createdAt         DateTime              @default(now())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
}

model IndexerCursor {
  id          String   @id @default(uuid())
  chainId     Int
  stream      String
  blockNumber BigInt
  updatedAt   DateTime @updatedAt

  @@unique([chainId, stream])
}

model IdempotencyRecord {
  id         String   @id @default(uuid())
  key        String
  scope      String
  response   Json
  statusCode Int
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([key, scope])
  @@index([expiresAt])
}
